{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist",
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",

    "baseUrl": "./src",
    "paths": {
      "*": ["*"]
    },

    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": false,
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": ["./**/*"],
  "exclude": ["node_modules"]
}


