{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist",

    "module": "NodeNext",
    "target": "esnext",
    "moduleResolution": "NodeNext",


    "paths": {
      "*": ["./node_modules/*", "./src/*"]
    },

    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["./**/*"],
  "exclude": ["node_modules"]
}